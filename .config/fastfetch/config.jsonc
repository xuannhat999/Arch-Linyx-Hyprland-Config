{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
      "source": "~/.config/fastfetch/logo.txt",
      "type": "file",
      "color": {
        "1": "38;5;111",
        "2": "38;5;147",
        "3": "38;5;115"
      }
  },
  "display": {
    "separator": " ➜  ",
    "color": {
      "keys": "38;5;147"
    },
    "noBuffer":true
  },
  "modules": [
    {
      "type": "os",
      "key": " 󰣇  SYSTEM  ",
      "keyColor": "38;5;111"
    },
    {
      "type": "kernel",
      "key": "   KERNEL  ",
      "keyColor": "38;5;111"
    },
    {
      "type": "wm",
      "key": " 󱂬  WINDOW  ",
      "keyColor": "38;5;111"
    },
    {
      "type": "command",
      "key": " 󰃭  AGE     ",
      "keyColor": "38;5;147",
      "text": "birth_install=$(stat -c %W / | tr -d '0' == '' && stat -c %Y / || stat -c %W /); now=$(date +%s); echo $(((now-birth_install)/86400)) days"
    },
    {
      "type": "uptime",
      "key": " 󰔛  UPTIME  ",
      "keyColor": "38;5;147"
    },
    {
      "type": "packages",
      "key": " 󰏖  PACKS   ",
      "keyColor": "38;5;147"
    },
    {
      "type": "localip",
      "key": " 󱦂  LOCAL IP",
      "keyColor": "38;5;147",
      "compact": true
    },
    {
      "type": "cpu",
      "key": " 󰍛  CPU     ",
      "keyColor": "38;5;115",
      "format": "{1}",
    },
    {
      "type": "gpu",
      "key": " 󰢮  GPU     ",
      "keyColor": "38;5;115",
      "format": "{2}"
    },
    {
      "type": "memory",
      "key": " 󰑭  RAM     ",
      "keyColor": "38;5;115",
      "format": "{1} / {2} ({3})"
    },
    {
      "type": "disk",
      "key": " 󰋊  DISK    ",
      "keyColor": "38;5;115",
      "format": "{1} / {2} ({3})"
    }
  ]
}
